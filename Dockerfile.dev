FROM python:3.10-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements-dev.txt ./
RUN pip install --upgrade pip && pip install --no-cache-dir -r requirements-dev.txt

# Code is bind-mounted at runtime — not copied here.

EXPOSE 8000
CMD ["uvicorn", "backend_sparqhub_django.asgi:application", "--host", "0.0.0.0", "--port", "8000", "--reload"]
