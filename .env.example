SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_HOST=localhost        # use 'db' inside Docker
DATABASE_NAME=mydb
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_PORT=5432

REDIS_URL=redis://localhost:6379/0    # use 'redis://redis:6379/0' inside Docker

CORS_ALLOWED_ORIGINS=http://localhost:3000
BACKEND_URL=http://localhost:8000
# Blank means host-only cookies (correct for local dev). In prod, if the
# frontend/backend are on sibling subdomains of the same domain, set this to
# the shared parent, e.g. .example.com — otherwise auth cookies never reach
# the frontend's own domain even though it's "same-site".
COOKIE_DOMAIN=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
FIELD_ENCRYPTION_KEY=
SENTRY_DSN=

# Generated-image storage (Cloudflare R2) — blank means local disk instead
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
R2_PUBLIC_DOMAIN=
